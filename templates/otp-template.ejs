<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <meta http-equiv="X-UA-Compatible" content="IE=edge">
    <title>Your Heydu Verification Code</title>
</head>
<body style="margin:0;padding:0;background-color:#eef2f7;font-family:-apple-system,BlinkMacSystemFont,'Segoe UI',Roboto,'Helvetica Neue',Arial,sans-serif;color:#0f172a;">
    <table role="presentation" style="width:100%;border-collapse:collapse;background-color:#eef2f7;padding:28px 12px;">
        <tr>
            <td align="center">
                <table role="presentation" style="width:100%;max-width:620px;border-collapse:separate;border-spacing:0;background-color:#ffffff;border:1px solid #e2e8f0;border-radius:14px;overflow:hidden;">
                    <tr>
                        <td style="padding:26px 30px;background-color:#0f172a;text-align:center;">
                            <img src="cid:heydu-logo" alt="Heydu" style="width:128px;height:auto;display:block;margin:0 auto 14px auto;" />
                            <p style="margin:0;font-size:20px;line-height:1.3;font-weight:700;color:#f8fafc;">Account Verification</p>
                        </td>
                    </tr>

                    <tr>
                        <td style="padding:30px;">
                            <p style="margin:0 0 10px 0;font-size:16px;line-height:1.5;color:#0f172a;">
                                Hello<%= (typeof name !== 'undefined' && name) || (typeof userName !== 'undefined' && userName) ? ', ' + (name || userName) : '' %>,
                            </p>
                            <p style="margin:0 0 20px 0;font-size:14px;line-height:1.7;color:#475569;">
                                Use the one-time password below to continue signing in to your Heydu account
                                <span style="display:inline-block;margin-top:4px;padding:3px 8px;background-color:#f8fafc;border:1px solid #e2e8f0;border-radius:6px;color:#334155;"><%= userEmail %></span>.
                            </p>

                            <table role="presentation" style="width:100%;border-collapse:collapse;margin:18px 0 22px 0;">
                                <tr>
                                    <td style="padding:22px;background-color:#f8fafc;border:1px solid #dbeafe;border-radius:12px;text-align:center;">
                                        <p style="margin:0 0 8px 0;font-size:12px;line-height:1.4;letter-spacing:0.7px;text-transform:uppercase;color:#64748b;font-weight:700;">One-Time Password</p>
                                        <div style="margin:0;font-size:38px;line-height:1.2;font-weight:800;letter-spacing:8px;color:#1d4ed8;font-family:Consolas,'Courier New',monospace;user-select:all;-webkit-user-select:all;">
                                            <%= otp %>
                                        </div>
                                        <p style="margin:10px 0 0 0;font-size:12px;color:#64748b;">Tap and hold to copy on mobile</p>
                                        <p style="margin:6px 0 0 0;font-size:12px;color:#dc2626;font-weight:700;">This code expires in 10 minutes</p>
                                    </td>
                                </tr>
                            </table>

                            <table role="presentation" style="width:100%;border-collapse:collapse;">
                                <tr>
                                    <td style="padding:14px 16px;background-color:#fff7ed;border:1px solid #fed7aa;border-radius:10px;">
                                        <p style="margin:0;font-size:13px;line-height:1.6;color:#9a3412;">
                                            <strong>Security notice:</strong> Never share this code with anyone. Heydu support will never ask for your verification code.
                                        </p>
                                    </td>
                                </tr>
                            </table>

                            <p style="margin:20px 0 0 0;font-size:13px;line-height:1.7;color:#64748b;">
                                If you did not request this code, you can safely ignore this email.
                            </p>
                        </td>
                    </tr>

                    <tr>
                        <td style="padding:0 30px;">
                            <div style="height:1px;background-color:#e2e8f0;"></div>
                        </td>
                    </tr>

                    <tr>
                        <td style="padding:22px 30px 24px 30px;text-align:center;">
                            <p style="margin:0 0 14px 0;font-size:13px;line-height:1.5;color:#64748b;">Need help? Contact our support team.</p>
                            <a href="mailto:connect@heydu.biz" style="display:inline-block;padding:10px 20px;border-radius:8px;background-color:#1d4ed8;color:#ffffff;text-decoration:none;font-size:13px;font-weight:600;">Contact Support</a>
                            <p style="margin:16px 0 0 0;font-size:12px;line-height:1.6;color:#94a3b8;">
                                &copy; <%= new Date().getFullYear() %> Heydu. All rights reserved.<br />
                                <a href="https://heydu.biz" style="color:#1d4ed8;text-decoration:none;">www.heydu.biz</a>
                            </p>
                        </td>
                    </tr>
                </table>

                <table role="presentation" style="width:100%;max-width:620px;border-collapse:collapse;margin-top:14px;">
                    <tr>
                        <td style="padding:0 8px;text-align:center;">
                            <p style="margin:0;font-size:11px;line-height:1.6;color:#94a3b8;">
                                This is an automated message. Please do not reply to this email.
                            </p>
                        </td>
                    </tr>
                </table>
            </td>
        </tr>
    </table>
</body>
</html>
