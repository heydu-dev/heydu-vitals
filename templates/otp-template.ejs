<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <meta http-equiv="X-UA-Compatible" content="IE=edge">
    <title>Your Heydu Verification Code</title>
</head>
<body style="margin:0;padding:0;background-color:#f3f4f6;font-family:-apple-system,BlinkMacSystemFont,'Segoe UI',Roboto,'Helvetica Neue',Arial,sans-serif;">
    <table role="presentation" style="width:100%;border-collapse:collapse;background-color:#f3f4f6;padding:40px 0;">
        <tr>
            <td align="center">
                <!-- Main Container -->
                <table role="presentation" style="width:100%;max-width:600px;background-color:#ffffff;border-radius:12px;box-shadow:0 4px 6px rgba(0,0,0,0.05);overflow:hidden;">
                    <!-- Header -->
                    <tr>
                        <td style="background:linear-gradient(135deg, #667eea 0%, #764ba2 100%);padding:32px 40px;text-align:center;">
                            <img src="cid:heydu-logo" alt="Heydu" style="width:140px;height:auto;margin-bottom:16px;" />
                            <h1 style="margin:0;color:#ffffff;font-size:24px;font-weight:600;letter-spacing:-0.5px;">Verification Code</h1>
                        </td>
                    </tr>
                    
                    <!-- Body -->
                    <tr>
                        <td style="padding:40px 40px 32px 40px;">
                            <p style="margin:0 0 8px 0;font-size:16px;color:#111827;font-weight:500;">Hello,</p>
                            <p style="margin:0 0 24px 0;font-size:15px;color:#6b7280;line-height:1.6;">
                                We received a request to access your Heydu account 
                                <span style="display:inline-block;padding:2px 8px;background-color:#f3f4f6;border-radius:4px;color:#374151;font-weight:500;"><%= userEmail %></span>
                            </p>
                            
                            <!-- OTP Box -->
                            <table role="presentation" style="width:100%;margin:32px 0;">
                                <tr>
                                    <td style="background:linear-gradient(135deg, #f9fafb 0%, #f3f4f6 100%);border:2px solid #e5e7eb;border-radius:12px;padding:32px;text-align:center;">
                                        <p style="margin:0 0 12px 0;font-size:13px;color:#9ca3af;text-transform:uppercase;letter-spacing:1px;font-weight:600;">Your Verification Code</p>
                                        <div style="font-size:40px;font-weight:700;letter-spacing:12px;color:#667eea;font-family:'Courier New',Courier,monospace;user-select:all;margin:0;padding:12px 0;">
                                            <%= otp %>
                                        </div>
                                        <p style="margin:12px 0 0 0;font-size:12px;color:#9ca3af;">
                                            <strong style="color:#ef4444;">Expires in 10 minutes</strong>
                                        </p>
                                    </td>
                                </tr>
                            </table>
                            
                            <!-- Security Notice -->
                            <table role="presentation" style="width:100%;background-color:#fef3c7;border-left:4px solid #f59e0b;border-radius:8px;padding:16px;margin:24px 0 0 0;">
                                <tr>
                                    <td>
                                        <p style="margin:0;font-size:14px;color:#92400e;line-height:1.5;">
                                            <strong style="display:block;margin-bottom:4px;">🔒 Security Tip</strong>
                                            Never share this code with anyone. Heydu support will never ask for your verification code.
                                        </p>
                                    </td>
                                </tr>
                            </table>
                            
                            <p style="margin:32px 0 0 0;font-size:14px;color:#9ca3af;line-height:1.6;">
                                If you didn't request this code, please ignore this email. Your account remains secure.
                            </p>
                        </td>
                    </tr>
                    
                    <!-- Divider -->
                    <tr>
                        <td style="padding:0 40px;">
                            <div style="height:1px;background-color:#e5e7eb;"></div>
                        </td>
                    </tr>
                    
                    <!-- Footer -->
                    <tr>
                        <td style="padding:32px 40px;text-align:center;">
                            <p style="margin:0 0 16px 0;font-size:14px;color:#6b7280;">
                                Need assistance? We're here to help.
                            </p>
                            <a href="mailto:connect@heydu.biz" style="display:inline-block;padding:12px 24px;background-color:#667eea;color:#ffffff;text-decoration:none;border-radius:6px;font-size:14px;font-weight:500;margin-bottom:24px;">
                                Contact Support
                            </a>
                            <p style="margin:0;font-size:12px;color:#9ca3af;line-height:1.6;">
                                © <%= new Date().getFullYear() %> Heydu. All rights reserved.<br/>
                                <a href="https://heydu.biz" style="color:#667eea;text-decoration:none;">www.heydu.biz</a>
                            </p>
                        </td>
                    </tr>
                </table>
                
                <!-- Footer Text -->
                <table role="presentation" style="width:100%;max-width:600px;margin-top:24px;">
                    <tr>
                        <td style="padding:0 20px;text-align:center;">
                            <p style="margin:0;font-size:11px;color:#9ca3af;line-height:1.5;">
                                This is an automated message, please do not reply to this email.<br/>
                                If you have questions, reach out at <a href="mailto:connect@heydu.biz" style="color:#667eea;text-decoration:none;">connect@heydu.biz</a>
                            </p>
                        </td>
                    </tr>
                </table>
            </td>
        </tr>
    </table>
</body>
</html>
